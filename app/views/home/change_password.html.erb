  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: #f4f4f4;
    }

    .container {
      max-width: 400px;
      margin: 50px auto;
      background-color: #fff;
      padding: 20px;
      border-radius: 5px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .field {
      margin-bottom: 20px;
    }

    label {
      display: block;
      font-weight: bold;
    }

    input[type="password"] {
      width: 100%;
      padding: 10px;
      font-size: 16px;
      border: 1px solid #ccc;
      border-radius: 5px;
      box-sizing: border-box;
    }

    .actions {
      text-align: center;
    }

    input[type="submit"] {
      background-color: #ff6700;
      color: #fff;
      border: none;
      padding: 10px 20px;
      font-size: 16px;
      cursor: pointer;
      border-radius: 5px;
    }

    input[type="submit"]:hover {
      background-color: #ff6700;
    }

     h2 {
      text-align: center;
    }
  </style>
<body>
  <div class="container">
    <h2>Password Change</h2>
    <%= form_with model: current_user, url: update_password_path, method: :patch do |f| %>
      <div class="field">
        <%= f.label :new_password %>
        <%= f.password_field :password, autocomplete: "new-password", required: true  %>
      </div>
      <div class="field">
        <%= f.label :confirm_password %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true %>
      </div>
      <div class="actions">
        <%= f.submit "Change Password" %>
      </div>
    <% end %>
  </div>
</body>
