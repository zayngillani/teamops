<div class="form-container">
  <%= form_with(model: @holiday, url: holiday_index_path, method: :post) do |form| %>

    <div class="form-group">
      <%= form.label :title, class: "label" %>
      <%= form.text_field :title, class: "text-field", required: true %>
    </div>

    <div class="form-group">
      <%= form.label :start_date, class: "label" %>
      <%= form.date_field :start_date, class: "text-field", required: true %>
    </div>
    
    <div class="form-group">
      <%= form.label :end_date, class: "label" %>
      <%= form.date_field :end_date, class: "password-field", required: true %>
    </div>

    <div class="form-actions">
      <%= form.submit "Add Holiday", class: "submit-button" %>
    </div>
  <% end %>
</div>