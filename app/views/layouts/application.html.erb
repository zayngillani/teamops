<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Work Portal</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= favicon_link_tag 'favicon.svg' %>

    <%
=begin%>
 <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %> 
<%
=end%>
    <%= stylesheet_link_tag "style", "data-turbo-track": "reload" %>
    <%
=begin%>
 <%= stylesheet_link_tag 'forgot_password', media: 'all', 'data-turbolinks-track': 'reload' %> 
<%
=end%>
    <%= javascript_importmap_tags %>
    <%= stylesheet_link_tag 'application' %>
    <%= javascript_include_tag 'application' %>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.2/css/all.min.css"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>


    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" integrity="sha512-Kc323vGBEqzTmouAECnVceyQqyqdsSiqLQISBL29aUW4U/M7pSPA/gEUZQqv1cwx4OnYxTxve5UMg5GT6L4JJg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
 
  </head>

  <body>





 <div class="d-flex">
      <!-- Sidebar -->
      <div class="sidebar">
 <% if user_signed_in? %>
        <aside class="flex-grow-1 bg-light">
          <%= render 'shared/sidebar' %>
        </aside>
      <% end %>
      </div>

      <!-- Main Content Area -->
      <div class="main-content w-100">
        <!-- Navbar -->
       <% if user_signed_in? %>
          <%= render 'shared/header' %>
          <%= render :partial => 'shared/message' %>


       
       
        <!-- Main Content -->
        <div class="container-fluid">
     










        </div>



         <% end %>
        <%= yield %>

      </div>
    </div>








    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.min.js" integrity="sha384-0pUGZvbkm6XF6gxjEnlmuGrJXVbNuzT9qBBavbLwCsOGabYfZo0T0to5eqruptLy" crossorigin="anonymous"></script>
  </body>
</html>
