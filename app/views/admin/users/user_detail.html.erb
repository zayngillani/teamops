<div class="main-content" style="margin-left: 220px; margin-top: 10px;">
<div class="form-inline">
<h1><%= @user&.name %>'s Attendance</h1>
<div class="detail-page float-right">
<%= form_tag admin_user_detail_path, method: :get, id: "filterForm" do %>
    <%= hidden_field_tag 'id', @user&.id %>
    <%= select_tag 'month', options_for_select(Date::MONTHNAMES.compact.each_with_index.map { |month, index| [month, index + 1] }, params[:month].presence || Date.current.month), id: 'month', class: 'form-control select-month' %>
    <%= select_tag 'year', options_for_select((Date.current.year..Date.current.year + 5).to_a, params[:year].presence || Date.current.year), id: 'year', class: 'form-control select-year' %>
<% end %>
</div>
</div>

<br>
<table class="attendance-table">
  <thead>
    <tr>
      <th>Date</th>
      <th>Check In</th>
      <th>Check Out</th>
      <th>Leaves</th>
      <th>Total Hours</th>
    </tr>
  </thead>
  <tbody>
    <% if @user_sessions.present? %>
      <% @user_sessions.each do |item| %>
      <tr>
        <td><%= item.created_at.strftime("%b %d, %Y")%></td>
        <td><%= item.check_in_time.in_time_zone("Asia/Karachi").strftime("%I:%M %p") %></td>
        <td><%= item.check_out_time.present? ? item.check_out_time.in_time_zone("Asia/Karachi").strftime("%I:%M %p") : "N/A"%></td>
        <td></td>
        <td>
          <% if item.total_hours.present? %>
            <%= "#{item.total_hours / 3600} hours #{item.total_hours % 3600 / 60} minutes" %>
          <% else %>
            N/A
          <% end %>
        </td>
      </tr>
      <% end %>
      <td><strong>Total</strong></td>
            <td></td>
            <td></td>
            <td><%= @leaves %></td>
      <td><strong><%= "#{@total_hours / 3600 || 0} hours #{@total_hours % 3600 / 60 || 0} minutes" %></strong></td>
    <% else %>
      <tr>
        <td colspan="5" class="no-data">No data available for <%= Date::MONTHNAMES[@month.to_i] %></td>
      </tr>
    <% end%>
    </tbody>
  </table>
</div>