<div class="form-container">
  <%= form_with(model: @user, url: admin_users_path, method: :post) do |form| %>
    <div class="form-group">
      <%= form.label :name, class: "label" %>
      <%= form.text_field :name, class: "text-field", required: true, maxlength: 25 %>
    </div>

    <div class="form-group">
      <%= form.label :email, "Personal Email", class: "label" %>
      <%= form.email_field :personal_email, class: "email-field", required: true, pattern: "\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b" %>
    </div>

    <div class="form-group">
      <%= form.label :supervisor, class: "label" %>
      <%= form.text_field :supervisor, class: "text-field", required: true, maxlength: 12 %>
    </div>

    <div class="form-group">
      <%= form.label :joining_date, class: "label" %>
      <%= form.date_field :join_date, class: "text-field", required: true %>
    </div>

    <div class="form-group">
      <%= form.label :is_github_required, "Is Github required?", class: "label" %>
      <%= form.check_box :is_github_required, class: "checkbox large-checkbox" %>
    </div>

    <div class="form-actions">
      <%= form.submit "Send Invitation", class: "submit-button" %>
    </div>
  <% end %>
</div>