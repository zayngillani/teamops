<div class="form-container">
  <%= form_with(model: @user, url: admin_users_path, method: :post) do |form| %>
    <div class="form-group">
      <%= form.label :email, class: "label" %>
      <%= form.email_field :email, class: "email-field", required: true, pattern: "\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b" %>
    </div>

    <div class="form-group">
      <%= form.label :name, class: "label" %>
      <%= form.text_field :name, class: "text-field", required: true, maxlength: 25 %>
    </div>

    <div class="form-group">
      <%= form.label :slack_Id, class: "label" %>
      <%= form.text_field :slack_member_id, class: "text-field", required: true %>
    </div>

    <div class="form-group">
      <%= form.label :supervisor, class: "label" %>
      <%= form.text_field :supervisor, class: "text-field", required: true, maxlength: 12 %>
    </div>

    <div class="form-group">
      <%= form.label :joining_date, class: "label" %>
      <%= form.date_field :join_date, class: "text-field", required: true %>
    </div>
    
    <div class="form-group">
      <%= form.label :password, class: "label" %>
      <%= form.password_field :password, class: "password-field", required: true, minlength: 6 %>
    </div>

    <div class="form-group">
      <%= form.label :password_confirmation, class: "label" %>
      <%= form.password_field :password_confirmation, class: "password-field", required: true, minlength: 6 %>
    </div>

    <div class="form-actions">
      <%= form.submit "Create User", class: "submit-button" %>
    </div>
  <% end %>
</div>