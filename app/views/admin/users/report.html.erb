  <div class="main-content" style="margin-left: 220px;"> <!-- Adjust margin-left to accommodate sidebar width -->
<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Name</th>
      <th>Email</th>
      <th>Attendance</th>
    </tr>
  </thead>
  <tbody>
  
    <% @session.each do |item| %>
    <tr>
      <td><%= item.id %></td>
      <td><%= item.name %></td>
      <td><%= item.email %></td>
      <td>
        <span>
            <button class="modal-btn styled-button" data-target="myModalPdf<%= item.id %>">Report</button>
            <div id="myModalPdf<%= item.id %>" class="modal">
              <div class="modal-content">
                <%= form_tag admin_generate_pdf_path(format: :pdf), method: :get do %>
                  <%= hidden_field_tag :id, item.id %>
                  <%= select_tag 'month', options_for_select(Date::MONTHNAMES.compact.each_with_index.map { |month, index| [month, index + 1] }, params[:month]), class: 'form-control pdf-set' %>
<%= select_tag 'year', options_for_select((Date.current.year..Date.current.year + 5).to_a, params[:year]), class: 'form-control' %>
                  <br>
                  <%= submit_tag 'Generate PDF', class: 'btn btn-primary styled-button2' %>
                <% end %>
              </div>
            </div>
        </span>
      </td>
    </tr>
    <% end %>

  </tbody>
</table>
<%= will_paginate @session, renderer: WillPaginate::ActionView::LinkRenderer, class: 'pagination' %>
</div>
