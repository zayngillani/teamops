<div class="main-content" style="margin-left: 260px; margin-top: 10px;">
  <div class="form-inline">
    <%= form_tag admin_monthly_users_list_path, method: :get, id: "filterForm" do %>
    <% selected_year = params[:year].presence || Date.current.year %>
    <%= select_tag 'month', options_for_select(
      if selected_year.to_i == Date.current.year
        Date::MONTHNAMES[1..Date.current.month].map.with_index(1) { |month, index| [month, index] }
      else
        Date::MONTHNAMES.compact.each_with_index.map { |month, index| [month, index + 1] }
      end,
      params[:month].presence || Date.current.month),
      id: 'month', class: 'form-control select-month' %>
    <%= select_tag 'year', options_for_select((2024..Date.current.year).to_a.reverse, selected_year), id: 'year', class: 'form-control select-year' %>
    <% end %>
    <p class="form-control select-hours">Expected Hours:<strong> <%= @total_working_hours %></strong></p>
    <button type="button" id="modal-btn-pdf" class="modal-btn btn-style float-right">Download PDF</button>
    <div id="myModalPdf" class="modal">
      <div class="modal-export">
        <div class="modal-header">
          <span class="report-close-modal" onclick="document.getElementById('myModalPdf').style.display='none'">&times;</span>
        </div>
        <h4>Select Columns to Export to PDF</h4><br>
        <%= form_tag admin_monthly_report_path(params[:month], params[:year]), method: :get do %>
          <label><%= check_box_tag 'expected_hours[]', 'expected_hours', true, class: 'PdfCheckbox' %> Expected Hours</label><br>
          <label><%= check_box_tag 'regular_hours[]', 'regular_hours', true, class: 'PdfCheckbox' %> Regular Hours</label><br>
          <label><%= check_box_tag 'worked_hours[]', 'worked_hours', true, class: 'PdfCheckbox' %> Worked Hours</label><br>
          <label><%= check_box_tag 'over_time[]', 'over_time', true, class: 'PdfCheckbox' %> Over Time</label><br>
          <label><%= check_box_tag 'under_time[]', 'under_time', true, class: 'PdfCheckbox' %> Under Time</label><br>
          <label><%= check_box_tag 'leaves[]', 'leaves', true, class: 'PdfCheckbox' %> Leaves</label><br>
          <label><%= check_box_tag 'absentees[]', 'absentees', true, class: 'PdfCheckbox' %> Absentees</label><br>
          <label><%= check_box_tag 'breaks[]', 'breaks', false, class: 'PdfCheckbox' %> Breaks</label>
          <%= submit_tag 'Download PDF', class: "excel-btn", onclick: "generatePDF(event)" %>
        <% end %>
        <p style="text-align: center; margin-top: 10px;"></p>
        <div class="modal-footer"></div>
      </div>
    </div>
    <button type="button" id="modal-btn" class="modal-btn btn-style">Download Excel</button>
    <div id="myModal" class="modal">
      <div class="modal-export">
        <div class="modal-header">
          <span class="report-close-modal" onclick="document.getElementById('myModal').style.display='none'">&times;</span>
        </div>
        <h4>Select Columns to Export</h4><br>
        <%= form_tag admin_users_monthly_excel_path(params[:month], params[:year]), method: :get, id: "exportForm" do %>
          <label><%= check_box_tag 'expected_hours[]', 'expected_hours', true, class: 'columnCheckbox' %> Expected Hours</label><br>
          <label><%= check_box_tag 'regular_hours[]', 'regular_hours', true, class: 'columnCheckbox' %> Regular Hours</label><br>
          <label><%= check_box_tag 'worked_hours[]', 'worked_hours', true, class: 'columnCheckbox' %> Worked Hours</label><br>
          <label><%= check_box_tag 'over_time[]', 'over_time', true, class: 'columnCheckbox' %> Over Time</label><br>
          <label><%= check_box_tag 'under_time[]', 'under_time', true, class: 'columnCheckbox' %> Under Time</label><br>
          <label><%= check_box_tag 'leaves[]', 'leaves', true, class: 'columnCheckbox' %> Leaves</label><br>
          <label><%= check_box_tag 'absentees[]', 'absentees', true, class: 'columnCheckbox' %> Absentees</label>
          <%= submit_tag 'Download Excel', class: "excel-btn", onclick: "downloadExcel(event, this)" %>
        <% end %>
        <p style="text-align: center; margin-top: 10px;"></p>
        <div class="modal-footer"></div>
      </div>
    </div>
  </div>
  <div id="users_data">
    <table>
      <thead>
        <tr>
          <th>Select All <input type="checkbox" id="select-all-users" /></th>
          <th>Name</th>
          <th>Total Hours</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td><%= check_box_tag 'selected_users[]', user.id, false, class: 'userCheckbox' %></td>
            <td><%= user&.name %></td>
            <td><%= "#{@total_hours[user.id] / 3600 || 0} hours #{@total_hours[user&.id] % 3600 / 60 || 0} minutes" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<script>
document.addEventListener('turbo:load', function() {
  // Open PDF modal
  document.getElementById('modal-btn-pdf')?.addEventListener('click', function() {
    document.getElementById('myModalPdf').style.display = 'block';
  });

  // Open Excel modal
  document.getElementById('modal-btn')?.addEventListener('click', function() {
    document.getElementById('myModal').style.display = 'block';
  });

  // Close modals
  document.querySelectorAll('.report-close-modal').forEach(function(closeButton) {
    closeButton.addEventListener('click', function() {
      document.getElementById('myModal').style.display = 'none';
      document.getElementById('myModalPdf').style.display = 'none';
    });
  });

  window.addEventListener('click', function(event) {
    if (event.target === document.getElementById('myModal')) {
      document.getElementById('myModal').style.display = 'none';
    }
    if (event.target === document.getElementById('myModalPdf')) {
      document.getElementById('myModalPdf').style.display = 'none';
    }
  });

  // Handle 'Select All' functionality
  const selectAllCheckbox = document.getElementById('select-all-users');
  selectAllCheckbox?.addEventListener('change', function() {
    const checkboxes = document.querySelectorAll('.userCheckbox');
    const isChecked = this.checked;
    checkboxes.forEach(function(checkbox) {
      checkbox.checked = isChecked;
    });
  });

  // Update 'Select All' checkbox state based on user checkboxes
  function updateSelectAllState() {
    const checkboxes = document.querySelectorAll('.userCheckbox');
    const checkedCheckboxes = document.querySelectorAll('.userCheckbox:checked');
    const selectAllCheckbox = document.getElementById('select-all-users');
    
    if (selectAllCheckbox) {
      if (checkboxes.length > 0 && checkboxes.length === checkedCheckboxes.length) {
        selectAllCheckbox.checked = true;
      } else {
        selectAllCheckbox.checked = false;
      }
    }
  }

  // Add event listener to each user checkbox to update 'Select All' state
  document.querySelectorAll('.userCheckbox').forEach(function(checkbox) {
    checkbox.addEventListener('change', updateSelectAllState);
  });

  // Initial check for 'Select All' state when page loads
  updateSelectAllState();
});

function generatePDF(event) {
  event.preventDefault();

  const selectedUsers = [];
  document.querySelectorAll('.userCheckbox:checked').forEach(function(checkbox) {
    selectedUsers.push(checkbox.value);
  });

  if (selectedUsers.length === 0) {
    alert('Please select at least one user.');
    return;
  }

  const columnCheckboxes = document.querySelectorAll('.PdfCheckbox:checked');
  if (columnCheckboxes.length === 0) {
    alert('Please select at least one column.');
    return;
  }

  const month = document.getElementById('month').value;
  const year = document.getElementById('year').value;

  const form = document.createElement('form');
  form.setAttribute('method', 'get');
  form.setAttribute('action', '<%= admin_monthly_report_path(format: :pdf) %>');

  const monthField = document.createElement('input');
  monthField.setAttribute('type', 'hidden');
  monthField.setAttribute('name', 'month');
  monthField.setAttribute('value', month);
  form.appendChild(monthField);

  const yearField = document.createElement('input');
  yearField.setAttribute('type', 'hidden');
  yearField.setAttribute('name', 'year');
  yearField.setAttribute('value', year);
  form.appendChild(yearField);

  const selectedColumns = [];
  columnCheckboxes.forEach(function(checkbox) {
    selectedColumns.push(checkbox.value);
  });

  const selectedColumnsField = document.createElement('input');
  selectedColumnsField.setAttribute('type', 'hidden');
  selectedColumnsField.setAttribute('name', 'selected_columns');
  selectedColumnsField.setAttribute('value', selectedColumns.join(','));
  form.appendChild(selectedColumnsField);

  const selectedUsersField = document.createElement('input');
  selectedUsersField.setAttribute('type', 'hidden');
  selectedUsersField.setAttribute('name', 'selected_users');
  selectedUsersField.setAttribute('value', selectedUsers.join(','));
  form.appendChild(selectedUsersField);

  document.body.appendChild(form);
  form.submit();
  document.body.removeChild(form);
}

function downloadExcel(event, button) {
  event.preventDefault();
  button.disabled = true;
  button.value = 'Processing...';

  const selectedUsers = [];
  document.querySelectorAll('.userCheckbox:checked').forEach(function(checkbox) {
    selectedUsers.push(checkbox.value);
  });

  if (selectedUsers.length === 0) {
    alert('Please select at least one user.');
    button.disabled = false;
    button.value = 'Download Excel';
    return;
  }

  const columnCheckboxes = document.querySelectorAll('.columnCheckbox:checked');
  if (columnCheckboxes.length === 0) {
    alert('Please select at least one column.');
    button.disabled = false;
    button.value = 'Download Excel';
    return;
  }

  const month = document.getElementById('month').value;
  const year = document.getElementById('year').value;

  const form = document.createElement('form');
  form.setAttribute('method', 'get');
  form.setAttribute('action', `<%= admin_users_monthly_excel_path(params[:month], params[:year]) %>?format=xlsx`);

  const monthField = document.createElement('input');
  monthField.setAttribute('type', 'hidden');
  monthField.setAttribute('name', 'month');
  monthField.setAttribute('value', month);
  form.appendChild(monthField);

  const yearField = document.createElement('input');
  yearField.setAttribute('type', 'hidden');
  yearField.setAttribute('name', 'year');
  yearField.setAttribute('value', year);
  form.appendChild(yearField);

  const selectedColumns = [];
  columnCheckboxes.forEach(function(checkbox) {
    selectedColumns.push(checkbox.value);
  });

  const selectedColumnsField = document.createElement('input');
  selectedColumnsField.setAttribute('type', 'hidden');
  selectedColumnsField.setAttribute('name', 'selected_columns');
  selectedColumnsField.setAttribute('value', selectedColumns.join(','));
  form.appendChild(selectedColumnsField);

  const selectedUsersField = document.createElement('input');
  selectedUsersField.setAttribute('type', 'hidden');
  selectedUsersField.setAttribute('name', 'selected_users');
  selectedUsersField.setAttribute('value', selectedUsers.join(','));
  form.appendChild(selectedUsersField);

  document.body.appendChild(form);
  form.submit();
  document.body.removeChild(form);

  // Reload the page after a short delay to ensure the download starts
  setTimeout(() => {
    location.reload();
  }, 5000); // Adjust delay as needed
}
</script>
