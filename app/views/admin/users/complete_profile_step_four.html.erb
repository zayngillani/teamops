<div class="form-container">
  <h1> Enter Slack ID & Githuib Username </h1>
  <br>
  <%= form_with model: @user, url: submit_information_admin_user_path(@user), method: :post do |f| %>
    <div>
        <%= f.label :slack_member_id, "Slack ID", class: "label" %>
        <%= f.text_field :slack_member_id, required: true, class: "text-field" %>
    </div>

    <div>
        <%= f.label :github_user_name, "Github Username", class: "label" %>
        <%= f.telephone_field :github_user_name, required: true, class: "text-field" %>
    </div>

    <div>
        <%= f.submit "Submit", class: "submit-button"  %>
        <%= link_to "Back", complete_profile_instructions_admin_user_path(@user) , class: "submit-button"  %>
    </div>
  <% end %>
</div>