<div class="form-container2">
  <div class="profile-picture">
    <span class="initial2"><%= @first_name + @last_name %></span>
  </div>
  <div class="profile-fields">
    <div class="form-group">
      <p><strong>Email:</strong></p>
        <%= @user.email %>
    </div>

    <div class="form-group">
      <p><strong>Name:</strong></p>
        <%= @user.name %>
    </div>

    <div class="form-group">
      <p><strong>Slack ID:</strong></p>
        <%= @user.slack_member_id.present? ? @user.slack_member_id : "TU7Q45YH78"%>
    </div>

    <div class="form-group">
        <p><strong>Joining Date:</strong></p>
          <%= @user.join_date.present? ? @user.join_date.strftime("#{@user.join_date.day} %b, %Y") : "N/A" %>
    </div>
  </div>
</div>