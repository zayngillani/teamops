<style>
  .attendance-table {
    border-collapse: collapse;
    width: 100%;
  }

  .attendance-table th,
  .attendance-table td {
    padding: 10px;
    border: 1px solid #ddd;
    text-align: left;
  }

  .attendance-table th {
    background-color: #87ceeb;
    font-weight: bold;
  }

  .attendance-heading {
    background-color: #87ceeb;
    color: white;
    padding: 10px;
  }

.user-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px; /* Adjust as needed */
}

.info-item {
  display: flex;
  align-items: center;
}

.info-key {
  margin-right: 10px;
  font-weight: bold;
}

.info-value {
  border-bottom: 1px dotted #000;
  padding-bottom: 2px;
}

  .absent-day {
    color: red;
    font-weight: bold;
  }
</style>

<h1 class="attendance-heading">Attendance Details</h1>
<div class="user-info">
  <div class="info-item">
    <p class="info-key">Employee:</p>
    <p class="info-value"><%= @user.name %></p>
  </div>
  <div class="info-item">
    <p class="info-key">Month:</p>
    <p class="info-value"><%= @user_sessions.first.created_at.strftime("%b %d, %Y") %></p>
  </div>
</div>
<div class="user-info">
  <div class="info-item">
    <p class="info-key">Supervisor:</p>
    <p class="info-value"><%= @user.supervisor %></p>
  </div>
  <div class="info-item">
    <p class="info-key">Regular Hours:</p>
    <p class="info-value">8</p>
  </div>
</div>
<br>
<table class="attendance-table">
  <thead>
    <tr>
      <th>Date</th>
      <th>Check In</th>
      <th>Check Out</th>
      <th>Leaves</th>
      <th>Total Hours</th>
    </tr>
  </thead>
  <tbody>
    <% @user_sessions.each do |item| %>
      <tr>
        <td><%= item.created_at.strftime("%A %b #{item.created_at.day.ordinalize}") %></td>
        <td><%= item.check_in_time.in_time_zone("Asia/Karachi").strftime("%I:%M %p") %></td>
        <td><%= item.check_out_time.present? ? item.check_out_time.in_time_zone("Asia/Karachi").strftime("%I:%M %p") : "N/A" %></td>
        <td></td>
        <td>
          <% if item.total_hours.present? %>
            <%= "#{item.total_hours / 3600} hours #{item.total_hours % 3600 / 60} minutes" %>
          <% else %>
            N/A
          <% end %>
        </td>
      </tr>
    <% end %>
    <% @public_holidays.each do |holiday| %>
  <tr>
    <td><strong><%= holiday.title %></strong></td>
    <td colspan="4"><%= holiday.start_date.strftime("%b %d, %Y") %> to <%= holiday.end_date.strftime("%b %d, %Y") %></td>
  </tr>
<% end %>
    <tr>
      <td><strong>Total</strong></td>
      <td></td>
      <td></td>
      <td><%= @leaves %></td>
      <td><strong><%= "#{@total_hours / 3600 || 0} hours #{@total_hours % 3600 / 60 || 0} minutes" %></strong></td>
    </tr>
  </tbody>
</table>
