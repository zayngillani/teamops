<style>
.attendance-table {
  border-collapse: collapse;
  width: 100%;
}

.attendance-table th, .attendance-table td {
  padding: 10px;
  border: 1px solid #ddd;
  text-align: left;
}

.attendance-table th {
  background-color: #87CEEB;
  font-weight: bold;
}

.attendance-heading {
  background-color: #87CEEB;
  color: white; /* Set text color to ensure readability */
  padding: 10px; /* Add padding for better appearance */
}

.user-info {
  display: flex;
  justify-content: space-between; /* Ensure space between left and right info */
  align-items: center;
}

.left-info {
  display: flex;
  align-items: center;
}

.user-info p {
  margin-right: 10px;
}

.username {
  border-bottom: 3px dotted #000;
  padding-bottom: 2px;
}

.right-info {
  display: flex;
  align-items: center;
  margin-right: 30px;
}

.right-info p {
  margin-left: 10px; /* Adjust margin to create space between left and right info */
}

.absent-day {
  color: red;
  font-weight: bold;
}

</style>
<h1 class="attendance-heading">Attendance Details</h1>
<div class="user-info">
  <div class="left-info">
    <p>Employee:</p>
    <span class="username"><strong><%= @user.name%></strong></span>
  </div>
  <div class="right-info">
    <p>Month</p>
      <span class="username"><%= @user_sessions.first.created_at.strftime("%b %d, %Y")%></span>
  </div>
</div>
<div class="user-info">
  <div class="left-info">
      <p>Supervisor:</p>
    <span class="username"><strong><%= @user.supervisor%></strong></span>
  </div>
  <div class="right-info">
    <p>Regular Hours</p>
      <span class="username">8</span>
  </div>
  </div>
<br>
<table class="attendance-table">
  <thead>
    <tr>
      <th>Date</th>
      <th>Check In</th>
      <th>Check Out</th>
      <th>Leaves</th>
      <th>Total Hours</th>
    </tr>
  </thead>
  <tbody>
    <% @user_sessions.each do |item| %>
      <tr>
        <td><%= item.created_at.strftime("%b %d, %Y")%></td>
        <td><%= item.check_in_time.in_time_zone("Asia/Karachi").strftime("%I:%M %p") %></td>
        <td><%= item.check_out_time.present? ? item.check_out_time.in_time_zone("Asia/Karachi").strftime("%I:%M %p") : "N/A"%></td>
        <td></td>
        <td>
          <% if item.total_hours.present? %>
            <%= "#{item.total_hours / 3600} hours #{item.total_hours % 3600 / 60} minutes" %>
          <% else %>
            N/A
          <% end %>
        </td>
      </tr>
      <% end%>
<td><strong>Total</strong></td>
      <td></td>
      <td></td>
      <td><%= @leaves %></td>
<td><strong><%= "#{@total_hours / 3600 || 0} hours #{@total_hours % 3600 / 60 || 0} minutes" %></strong></td>
</td>
    </tbody>
  </table>
