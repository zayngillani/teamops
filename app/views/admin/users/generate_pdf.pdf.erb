<!DOCTYPE html>
<html>
<head>
  <title>Attendance Details</title>
  <style>
    .attendance-table {
      border-collapse: collapse;
      width: 100%;
    }

    .attendance-table th,
    .attendance-table td {
      padding: 10px;
      border: 1px solid #ddd;
      text-align: left;
    }

    .attendance-table th {
      background-color: #87ceeb;
      font-weight: bold;
    }

    .attendance-heading {
      background-color: #87ceeb;
      color: white;
      padding: 10px;
    }

    .user-info {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .left-info {
      display: flex;
      align-items: left;
    }

    .user-info p {
      margin-right: 10px;
    }

    .username {
      border-bottom: 3px dotted #000;
      padding-bottom: 2px;
    }

    .right-info {
      display: flex;
      align-items: right;
      margin-right: 30px;
    }

    .right-info p {
      margin-left: 10px;
    }

    .absent-day {
      color: red;
      font-weight: bold;
    }
  </style>
</head>
<body>

<h1 class="attendance-heading">Attendance Details</h1>
<p style="float: left; margin: 5px;">Employee:</p>
<p style="float: right; margin: 5px;">Month:  <strong><%= @user_sessions.first.created_at.strftime("%b") %></strong></p>
<div style="display: flex; justify-content: space-between; align-items: center; margin: 5px;">
  <span style="margin: 5px;"><strong><%= @user.name %></strong></span>
</div>
  <br>
  <br>
  <p style="float: left; margin: 5px;">Supervisor:</p>
  <span style="float: left; margin: 5px;"><strong><%= @user.supervisor.present? ? @user.supervisor : "Fahad" %></strong></span>
  <span style="float: right; margin: 5px;"></span>
<div style="display: flex; justify-content: space-between; align-items: center; margin: 5px;">
  <p style="float: right; margin: 0; margin-right: 10px;">Regular Hours:8</p>
</div>
  <br>
  <br>
<table class="attendance-table">
  <thead>
    <tr>
      <th>Date</th>
      <th>Check In</th>
      <th>Check Out</th>
      <th>Leaves</th>
      <th>Total Hours</th>
    </tr>
  </thead>
  <tbody>
    <% @user_sessions.each do |item| %>
      <tr>
        <td><%= item.created_at.strftime("%A %b #{item.created_at.day.ordinalize}") %></td>
        <td><%= item.check_in_time.in_time_zone("Asia/Karachi").strftime("%I:%M %p") %></td>
        <td><%= item.check_out_time.present? ? item.check_out_time.in_time_zone("Asia/Karachi").strftime("%I:%M %p") : "N/A" %></td>
        <td></td>
        <td>
          <% if item.total_hours.present? %>
            <%= "#{item.total_hours / 3600} hours #{item.total_hours % 3600 / 60} minutes" %>
          <% else %>
            N/A
          <% end %>
        </td>
      </tr>
    <% end %>
    <% @public_holidays.each do |holiday| %>
  <tr>
    <td><strong><%= holiday.title %></strong></td>
    <td colspan="4"><%= holiday.start_date.strftime("%b %d, %Y") %> to <%= holiday.end_date.strftime("%b %d, %Y") %></td>
  </tr>
<% end %>
    <tr>
      <td><strong>Total</strong></td>
      <td></td>
      <td></td>
      <td><%= @leaves %></td>
      <td><strong><%= "#{@total_hours / 3600 || 0} hours #{@total_hours % 3600 / 60 || 0} minutes" %></strong></td>
    </tr>
  </tbody>
</table>
</body>
</html>