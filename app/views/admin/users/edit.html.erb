<div class="form-container">
  <% if @user.errors.any? %>
    <div id="error_explanation" class="error-message">
      <h2><%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:</h2>
      <ul>
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with(model: @user, url: admin_user_path, method: :patch) do |form| %>
    <div class="form-group">
      <%= form.label :email, class: "label" %>
      <%= form.email_field :email, class: "email-field", required: true %>
    </div>

    <div class="form-group">
      <%= form.label :name, class: "label" %>
      <%= form.text_field :name, class: "text-field", required: true %>
    </div>

    <div class="form-group">
      <%= form.label :slack_Id, class: "label" %>
      <%= form.text_field :slack_member_id, class: "text-field", required: true %>
    </div>

    <div class="form-group">
      <%= form.label :password, class: "label" %>
      <%= form.password_field :password, class: "password-field" %>
    </div>

    <div class="form-group">
      <%= form.label :password_confirmation, class: "label" %>
      <%= form.password_field :password_confirmation, class: "password-field" %>
    </div>

    <div class="form-actions">
      <%= form.submit "Update User", class: "submit-button" %>
    </div>
  <% end %>
</div>