<style>
.attendance-table {
  border-collapse: collapse;
  width: 100%;
}

.attendance-table th, .attendance-table td {
  padding: 10px;
  border: 1px solid #ddd;
  text-align: left;
}

.attendance-table th {
  background-color: #87CEEB;
  font-weight: bold;
}

.attendance-heading {
  background-color: #87CEEB;
  color: white; /* Set text color to ensure readability */
  padding: 10px; /* Add padding for better appearance */
}
</style>
<h1 class="attendance-heading">Monthly Report</h1>
<table class="attendance-table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Total Hours</th>
    </tr>
  </thead>
  <tbody>
<% @users.each do |user| %>
    <tr>
      <td><%= user.name %></td>
      <td><%= "#{@total_hours[user.id] / 3600 || 0} hours" %></td>
      </tr>
      <% end%>
    </tbody>
  </table>
