<div class="main-content" style="margin-left: 220px;">
<%= link_to "Create Employee", new_admin_user_path, class: "sign-out-button", id: "checkInButton", style: "float: right; margin-right: 20px; margin-bottom: 10px; margin-top: 15px;" %>
<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Name</th>
      <th>Email</th>
      <th>IP Address </th>
      <th>Attendance</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
  
    <% @session.each do |item| %>
    <tr>
      <td><%= item.id %></td>
      <td><%= item.name %></td>
      <td><%= item.email %></td>
      <td><%= item.ip_address.present? ? item.ip_address : "N/A"%>
      <td>
        <%= link_to "View", admin_user_detail_path(id: item.id), class: "sign-out-button"%>
      </td>
      <td>
      <div class="dropdown-action">
      <%= image_tag("more.png", width: "20", height: "20", alt: "Edit User")%>
  <div class="dropdown-content-action">
<div class="actions-container">
  <button class="modal-btn" onclick="window.location.href='<%= edit_admin_user_path(item.id) %>'">Edit</button>

  <button class="modal-btn" data-target="myModalDelete<%= item.id %>"> Delete</button>
<div id="myModalDelete<%= item.id %>" class="modal">
    <div class="modal-content">
        <p style="text-align: center; margin-top: 10px;">Are you sure you want to Delete this User?</p>
        <div id="timerDisplayModal"></div>
        <div class="modal-footer">
            <%= button_to "Yes, Delete", admin_user_path(item.id), method: :delete, class: "sign-out-button delete-btn" %>
            <button class="closeModalBtn close sign-out-button">No</button>
        </div>
    </div>
</div>

<button class="modal-btn" data-target="myModalDisable<%= item.id %>"><%= item.status == "active" ? "Disable" : "Un-disable"%>
</button>

<div id="myModalDisable<%= item.id %>" class="modal">
    <div class="modal-content">
        <p style="text-align: center; margin-top: 10px;">Are you sure you want to <%= item.status == "active" ? "Disable" : "Enable" %> this User?</p>
        <div id="timerDisplayModal"></div>
        <div class="modal-footer">
            <%= button_to(item.status == "active" ? "Yes, Disable" : "Yes, Enable", admin_disable_user_path(id: item.id), method: :put, class: "sign-out-button delete-btn") %>
            <button class="closeModalBtn close sign-out-button">No</button>
        </div>
    </div>
</div>
  </div>
</div>
</div>

</td>
    </tr>
    <% end %>

  </tbody>
</table>
<%= will_paginate @session, renderer: WillPaginate::ActionView::LinkRenderer, class: 'pagination' %>
</div>
