<tr class="dashboard-table-lines">
  <td class="table-first-column">
    <%= contact_detail.details['name'].present? ? contact_detail.details['name'] : 'N/A' %>
  </td>
  <td class="table-first-column">
    <%= contact_detail.details['email'].present? ? contact_detail.details['email'] : 'N/A' %>
  </td>
  <td class="table-first-column">
    <%= contact_detail.details['contact_no'].present? ? contact_detail.details['contact_no'] : 'N/A' %>
  </td>
  <td class="table-first-column">
    <%= contact_detail.details['project_details'].present? ? contact_detail.details['project_details'].split(' ').first(4).join(' ') + '...' : 'N/A' %>
  </td>
  <td class="table-first-column">
    <%= contact_detail.contact_type.present? ? contact_detail.contact_type : 'N/A' %>
  </td>
  <td class="table-first-column">
    <%= link_to "view", admin_contact_detail_path(contact_detail), style: "color: #536779; text-decoration: none;" %>
  </td>  
</tr>
