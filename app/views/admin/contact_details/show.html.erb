<div class="card">
  <div class="card-header">
    <h2>Contact Detail</h2>
  </div>
  <div class="card-body">
    <p><strong>Type:</strong> <%= @contact_detail.contact_type.present? ? @contact_detail.contact_type.underscore.humanize.titleize : 'N/A' %></p>
    <p><strong>Name:</strong> <%= @contact_detail.details['name'].present? ? @contact_detail.details['name'] : 'N/A' %></p>
    <p><strong>Email:</strong> <%= @contact_detail.details['email'].present? ? @contact_detail.details['email'] : 'N/A' %></p>
    <p><strong>Contact:</strong> <%= @contact_detail.details['contact_no'].present? ? @contact_detail.details['contact_no'] : 'N/A' %></p>
    <p><strong>Project Details:</strong> <%= @contact_detail.details['project_details'].present? ? @contact_detail.details['project_details'] : 'N/A' %></p>
  </div>
</div>
<style>
  /* contact details page for admin */
  .card {
    height: auto;
    display: flex;
    position: absolute;
    justify-content: center;
    flex-direction: column;
    border: 1px solid #ccc;
    border-radius: 8px;
    padding: 16px;
    max-width: 600px;
    margin: auto;
    margin-top: 30px;
    left: 35%;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    background-color: #fff;
  }

  .card-header {
    text-align: center;
    border-bottom: 1px solid #eee;
    padding-bottom: 10px;
    margin-bottom: 15px;
  }

  .card-header h2 {
    margin: 0;
    font-size: 1.5em;
    color: #333;
  }

  .card-body p {
    margin: 12px 0;
    font-size: 1em;
    color: #555;
    line-height: 1.6;
  }

  .card-body p strong {
    color: #000;
  }

  @media (max-width: 768px) {
    .card {
      padding: 12px;
      max-width: 95%;
    }

    .card-header h2 {
      font-size: 1.3em;
    }

    .card-body p {
      font-size: 0.9em;
    }
  }
</style>