<% content_for :link_button do %>
  <div style="margin-left: 294px; position: absolute;">
    <div class="search-container">
<%= form_with url: admin_daily_reports_path, method: :get, local: false, id: 'search-form', data: { controller: 'search', action: 'input->search#performSearch' } do |form| %>
  <%= form.text_field :q, placeholder: 'Search', id: 'search-query', data: { target: 'search.query' } %>
<% end %>
      <svg class="search-icon" viewBox="0 0 24 24">
        <path d="M10 2a8 8 0 1 0 4.9 14.4l5.6 5.6 1.4-1.4-5.6-5.6A8 8 0 0 0 10 2zm0 2a6 6 0 1 1 0 12 6 6 0 0 1 0-12z"/>
      </svg>
    </div>
  </div>
<% end %>

<div class="reportTable">
  <%= render partial: 'search', locals: { users: @users } %>
</div>

