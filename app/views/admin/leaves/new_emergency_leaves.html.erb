<style>
/* Styling for modal and error messages */
.modal {
  display: none;
  position: fixed;
  z-index: 1;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  overflow: auto;
  background-color: rgba(0, 0, 0, 0.4);
}

.modal-content {
  background-color: #fefefe;
  margin: 15% auto;
  padding: 20px;
  border: 1px solid #888;
  width: 300px;
  position: relative;
}

.close {
  color: #aaa;
  float: right;
  font-size: 28px;
  font-weight: bold;
  cursor: pointer;
}

.close:hover,
.close:focus {
  color: black;
  text-decoration: none;
  cursor: pointer;
}

.error-message {
  color: red;
  font-size: 12px;
  margin-top: 5px;
}

/* Container to hold dropdowns and the button */
.form-inline-container {
  display: flex;
  justify-content: space-between; /* Align items to the left and right */
  align-items: center; /* Center items vertically */
  gap: 20px; /* Space between dropdowns and the button */
  width: 100%; /* Full width container */
}

/* Container for the dropdowns */
.dropdown-container {
  display: flex;
  gap: 20px; /* Space between the dropdowns */
  align-items: flex-start; /* Align dropdowns to the top */
  margin-right: 500px;
}

/* Container for the button */
.continue-button-container {
  display: flex;
  justify-content: flex-end; /* Push button to the right */
}


</style>

<% content_for :link_button do %>
  <%= form_with url: create_emergency_leaves_admin_leaves_path, method: :post, id: 'leaveForm', local: true do %>
    <div class="form-inline-container">
      <!-- Container for dropdowns -->
      <div class="dropdown-container">
        <div class="form-group">
          <%= select_tag 'leave_type', 
            options_for_select(
              [["Quarterly", "quarterly"], ["Annual", "annual"]], 
              params[:leave_type]
            ), 
            id: 'leave_type', 
            class: 'form-control select-leave-type', 
            prompt: 'Select Leave Type' %>
          <span id="leaveTypeError" class="error-message" style="display: none;">This field is required.</span>
        </div>

        <div class="form-group">
          <%= select_tag 'reason', 
            options_for_select(
              [["Personal", "personal"], ["Medical", "medical"], ["Family", "family"]], 
              params[:reason]
            ), 
            id: 'reason', 
            class: 'form-control select-reason', 
            prompt: 'Select Reason' %>
          <span id="reasonError" class="error-message" style="display: none;">This field is required.</span>
        </div>
      </div>

      <!-- Continue button on the right side -->
      <div class="continue-button-container">
        <button type="button" class="sign-out-button w-auto" id="continueBtn" onclick="openCalendarModal()">
          Continue
        </button>
      </div>
    </div>
  <% end %>
<% end %>

<div class="main-content" style="margin-left: 260px; margin-top: 10px;">
  <div id="users_data">
    <table>
      <thead>
        <tr>
          <th></th>
          <th>Name</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td>
              <%= radio_button_tag 'selected_user', user.id, false, class: 'userCheckbox' %>
            </td>
            <td><%= user&.name %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <div class="pagination-container">
    <%= will_paginate @users, renderer: PaginationHelper::DailyReportsRenderer, remote: true %>
    </div>
  </div>
</div>

<div id="calendarModal" class="modal">
  <div class="modal-content">
    <span class="close" onclick="closeCalendarModal()">&times;</span>
    <h3>Select Date</h3>
    <input type="date" id="leaveDate" class="form-control">
    <button class="sign-out-button w-auto" id="submitDateBtn" onclick="submitLeaveForm()">
      Submit
    </button>
  </div>
</div>

<script>
// Wait until the document is fully loaded
document.addEventListener('DOMContentLoaded', function () {
  const leaveType = document.getElementById('leave_type');
  const reason = document.getElementById('reason');
  const continueBtn = document.getElementById('continueBtn');

  // Validate selections to enable or disable the Continue button
  function validateSelections() {
    continueBtn.disabled = !(leaveType.value && reason.value);
  }

  // Handle radio button clicks to ensure only one user is selected
  window.handleCheckboxClick = function (checkbox) {
    document.querySelectorAll('.userCheckbox').forEach(cb => {
      if (cb !== checkbox) cb.checked = false;
    });
  };

  // Attach change event listeners to validate the selections
  leaveType.addEventListener('change', validateSelections);
  reason.addEventListener('change', validateSelections);

  validateSelections(); // Initial validation
});

// Open the calendar modal after validating the required fields
function openCalendarModal() {
  const leaveType = document.getElementById('leave_type');
  const reason = document.getElementById('reason');
  const leaveTypeError = document.getElementById('leaveTypeError');
  const reasonError = document.getElementById('reasonError');
  
  // Reset error messages
  leaveTypeError.style.display = 'none';
  reasonError.style.display = 'none';
  
  // Validate fields before opening the modal
  let valid = true;

  if (!leaveType.value) {
    leaveTypeError.style.display = 'block';
    valid = false;
  }
  if (!reason.value) {
    reasonError.style.display = 'block';
    valid = false;
  }

  if (!valid) {
    return;
  }

  const selectedUser = document.querySelector('input[name="selected_user"]:checked');
  if (!selectedUser) {
    alert('Please select one user.');
    return;
  }

  document.getElementById('calendarModal').style.display = 'block';
}

// Close the calendar modal
function closeCalendarModal() {
  document.getElementById('calendarModal').style.display = 'none';
}

// Submit the form with the selected date, user, leave type, and reason
function submitLeaveForm() {
  const selectedDate = document.getElementById('leaveDate').value;
  if (!selectedDate) {
    alert('Please select a date.');
    return;
  }

  const form = document.getElementById('leaveForm');
  const selectedUser = document.querySelector('input[name="selected_user"]:checked').value;

  // Append selected user, date, and other fields to the form
  const userInput = document.createElement('input');
  userInput.type = 'hidden';
  userInput.name = 'selected_user_id';
  userInput.value = selectedUser;
  form.appendChild(userInput);

  const dateInput = document.createElement('input');
  dateInput.type = 'hidden';
  dateInput.name = 'selected_date';
  dateInput.value = selectedDate;
  form.appendChild(dateInput);

  form.submit();
}
</script>
