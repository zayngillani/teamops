<div class="main-content">
  <div class="dashboard-form-container">
    <div class="job-form">
      <%= form_with(model: @job_post, url: admin_job_posts_path, method: :post, local: true) do |form| %>
        <div class="job-title-field">
          <%= form.text_field :title, class: 'form-control', placeholder: 'Job Title' %>
        </div>

        <div class="job-detail-field">
          <%= form.text_area :details, class: 'form-control', placeholder: 'Job Details' %>
        </div>

        <div class="job-detail-field">
          <%= form.text_area :requirements_and_qualification, class: 'form-control', placeholder: 'Requirements & Qualifications' %>
        </div>

        <div class="job-post-btn">
          <%= form.submit 'Publish Job', class: 'job-post-btn-text' %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
document.addEventListener('turbo:load', function() {
  document.querySelectorAll('.job-post-btn-text').forEach(function(button) {
    button.addEventListener('click', function() {
      this.disabled = true;
      this.form.submit();
    });
  });
});
</script>
