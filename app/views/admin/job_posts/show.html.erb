<div class="main-content" style="margin-left: 260px;">
  <div class="dashboard-table-container">
    <div class="dashboard-heading-position">
      <div class="dashboard-heading">
        <%= @job_post.title %>
        <%= link_to edit_admin_job_post_path(@job_post) do %>
          <img src="<%= asset_path('edit-icon.svg') %>" alt="Lock Icon" class="edit-icon-style">
        <% end %>
      </div>

      <%= link_to admin_job_applications_path, class: "applicants-list-btn" do %>
        <div class="applicants-list-btn-text">
          <span>10</span> Applicants
        </div>
      <% end %>
    </div>

    <div class="job-description-box">
      <h3> Job Deatils </h3><br>
      <div class="job-description-details">
        <p class="job-description-box-text"><%= @job_post.details %></p>
      </div>

      <h3> Requirements & Qualifications </h3><br>
      <div class="job-description-requirements">
        <p class="job-description-box-text"><%= @job_post.requirements_and_qualification %></p>
      </div>
    </div>
  </div>
</div>
