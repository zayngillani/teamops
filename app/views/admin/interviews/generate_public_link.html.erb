
<div style="margin-left: 260px;">
  <div class="dashboard-table-container">
    <h4>Share Details link has been generated for the interview, you can send this link to Interviewer for reminder</h4>
    <br>
    <p><strong>Interview Details link:</strong> 
      <a id="link-to-copy" href="<%= @public_link_url %>"><%= @public_link_url %></a>
      <button id="copy-btn" class="copy-btn-link" onclick="copyToClipboard()">Copy Link</button>
    </p>
  </div>
</div>

<script>
  function copyToClipboard() {
    var copyText = document.getElementById("link-to-copy").innerText;
    var copyButton = document.getElementById("copy-btn");

    navigator.clipboard.writeText(copyText).then(function() {
      copyButton.innerText = "Copied";
      setTimeout(function() {
        copyButton.innerText = "Copy Link";
      }, 20000); // Reset button text after 2 seconds
    }, function(err) {
      console.error("Failed to copy link: ", err);
    });
  }
</script>
