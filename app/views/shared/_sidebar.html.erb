<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sidebar</title>
    <link rel="stylesheet">
    <style>
        .sidebar {
            height: 100vh;
            width: 250px;
            background-color: white;
            box-shadow: 2px 0 5px rgba(0,0,0,0.1);
            position: fixed;
            top: 0;
            left: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            z-index: 1000;
        }

        .logo {
            margin: 20px 0;
            text-align: center;
        }

        .logo img {
            width: 156px;
            height: auto;
            margin-right: 42px;
            margin-top: 35px;
        }

        .logo h1 {
            margin: 10px 0 0;
            font-size: 24px;
            color: #ff7f00;
        }

        .menu {
            width: 100%;
            margin-top: -38px;
        }

        .menu a {
            text-decoration: none;
            width: 100%;
        }

        .menu-item {
            display: flex;
            align-items: center;
            padding: 15px 20px;
            color: #6c757d;
            transition: background-color 0.3s, color 0.3s, border 0.3s;
        }

        .menu-item:hover,
        .menu-item.active {
            background-color: #fff;
            color: black;
            border-radius: 10px;
            padding: 14px 19px;
        }

        .menu-item.active {
            background-color: #ffe8d6;
            font-weight: bold;
        }

        .menu-item::before {
            content: '';
            display: inline-block;
            margin-right: 10px;
            width: 20px;
            height: 20px;
            background-size: contain;
        }


        .menu-item:nth-child(2)::before {
            background-image: url('attendance-icon.svg');
        }

        .menu-item:nth-child(3)::before {
            background-image: url('report-icon.svg');
        }

        .menu-item:nth-child(4)::before {
            background-image: url('leaves-icon.svg');
        }

        .menu-icon {
            margin-right: 10px;
        }

        /* Media Queries */
        @media only screen and (max-width: 768px) {
            .sidebar {
                width: 200px;
            }

            .logo img {
                width: 90px;
            }

            .menu-item {
                padding: 12px 16px;
            }
        }

        @media only screen and (max-width: 480px) {
            .sidebar {
                width: 150px;
            }

            .logo img {
                width: 80px;
            }

            .menu-item {
                padding: 10px 14px;
                font-size: 14px;
            }
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="logo">
            <%= image_tag "logo.svg" %>
        </div>
        <% if current_user.admin? %>
            <div class="menu">
                <a href="<%= admin_users_path %>">
                    <div class="menu-item <%= 'active' if current_page?(admin_users_path) %>">
                        <%= image_tag("employee.svg", class: "menu-icon") %>
                        Employees
                    </div>
                </a>
                <a href="<%= admin_daily_reports_path %>">
                    <div class="menu-item <%= 'active' if current_page?(admin_daily_reports_path) %>">
                        <%= image_tag("dailyreport.svg", class: "menu-icon") %>
                        Daily Reports
                    </div>
                </a>
                <a href="<%= leaves_path %>">
                    <div class="menu-item <%= 'active' if current_page?(leaves_path) %>">
                        <%= image_tag("leave.svg", class: "menu-icon") %>
                        Leaves
                    </div>
                </a>
                <a href="<%= public_holidays_path %>">
                    <div class="menu-item <%= 'active' if current_page?(public_holidays_path) %>">
                        <%= image_tag("holiday.svg", class: "menu-icon") %>
                        Public Holidays
                    </div>
                </a>
                <a href="<%= admin_archived_user_path %>">
                    <div class="menu-item <%= 'active' if current_page?(admin_archived_user_path) %>">
                        <%= image_tag("archived.svg", class: "menu-icon") %>
                        Archived
                    </div>
                </a>
                <a href="<%= admin_report_path %>">
                    <div class="menu-item <%= 'active' if current_page?(admin_report_path) %>">
                        <%= image_tag("dailyreport.svg", class: "menu-icon") %>
                        Reports
                    </div>
                </a>
                <a href="<%= admin_job_posts_path %>">
                    <div class="menu-item <%= 'active' if current_page?(admin_job_posts_path) %>">
                        <%= image_tag("jobs-icon.svg", class: "menu-icon") %>
                        Jobs
                    </div>
                </a>
                <a href="<%= admin_contact_details_path %>">
                    <div class="menu-item <%= 'active' if current_page?(admin_contact_details_path) %>">
                        <%= image_tag("contact-us-icon.svg", class: "menu-icon") %>
                        Contact Details
                    </div>
                </a>
            </div>
        <% else %>
            <div class="menu">
                <a href="<%= attendance_index_path %>">
                    <div class="menu-item <%= 'active' if current_page?(attendance_index_path) %>">
                        <%= image_tag("dashboard.svg", class: "menu-icon") %>
                        Dashboard
                    </div>
                </a>
                <a href="#">
                    <div class="menu-item <%= 'active' if current_page?(root_path) %>">
                        <%= image_tag("attendance.svg", class: "menu-icon") %>
                        Attendance
                    </div>
                </a>
                <a href="<%= show_report_path %>">
                    <div class="menu-item <%= 'active' if current_page?(show_report_path) %>">
                        <%= image_tag("dailyreport.svg", class: "menu-icon") %>
                        Daily Reports
                    </div>
                </a>
                <a href="#">
                    <div class="menu-item <%= 'active' if current_page?(root_path) %>">
                        <%= image_tag("leave.svg", class: "menu-icon") %>
                        Leaves
                    </div>
                </a>
            </div>
        <% end %>
    </div>
</body>
</html>
