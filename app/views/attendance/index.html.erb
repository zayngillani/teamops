<style>
  body {
    background-color: #f1f1f1; /* off-white background */
    margin: 0;
    padding: 0;
  }
  .attendance-detail {
  display: flex;
  margin-right: 19%;
  gap: 8px;
}
  .break{
    width: 133px;
  }

  .checkin{
    width: 195px;
  }
  
  

  </style>
  <body>
  <% content_for :link_button do %>
    <div class="attendance-detail">
      <%  today = Date.current
          current_user_attendance = Attendance.where(user_id: current_user.id, check_in_time: today.all_day).first
          if current_user_attendance && current_user_attendance.check_out_time.present?
            session_time = current_user_attendance.check_out_time - current_user_attendance.check_in_time
          else
            session_time = Time.now - current_user_attendance.check_in_time if current_user_attendance
          end        
          if current_user_attendance.present?
            break_time = current_user_attendance.total_break || 0
            break_time = break_time.to_i
            total_break_minutes = (break_time / 60).to_i
            break_hours = format("%d:%02d h", total_break_minutes / 60, total_break_minutes % 60)
          else
            break_hours = "0:00 h"
            total_break_minutes = 0
          end
          
          if session_time
            total_worked_minutes = (session_time / 60).to_i
            worked_time = format("%d:%02d h", total_worked_minutes / 60, total_worked_minutes % 60)
            
            net_worked_minutes = total_worked_minutes - total_break_minutes
            if net_worked_minutes >= 0
              net_worked_time = format("%d:%02d h", net_worked_minutes / 60, net_worked_minutes % 60)
            else
              net_worked_time = "0:00 h"
            end
          else
            worked_time = "0:00 h"
            net_worked_time = "0:00 h"
          end
      %>
      <p class="form-control select-leave checkin"><strong>Checked in:</strong><span style="float: inline-end;"> <%= current_user_attendance.present? ? current_user_attendance.check_in_time.in_time_zone("Asia/Karachi").strftime("%I:%M %p") : "00:00"%></span></p>
      <p class="form-control select-leave"><strong>Worked Hours:</strong><span style="float: inline-end;"> <%= net_worked_time %></span></p>
      <p class="form-control select-leave break"><strong>Break:</strong><span style="float: inline-end;"> <%= break_hours %></span></p>
    </div>
<% end %>
<div class="content" style="margin-left: 220px;">
  <div class="card">
    <h3>Welcome</h3>
    <h1><%= current_user.name %></h1>
    <h4>Have a nice day at work</h4>
    <div class="button-container">

      <% session = current_user.attendances.order(created_at: :asc).last %>

      <% if current_user.attendances.empty? || current_user.attendances.last.check_in_time <= 16.hours.ago || session.total_hours.present? %>
        <% content_for :link_button do %>
          <%= button_to "Check-In", create_session_path, class: "sign-out-button check-btn", data: { disable_with: "Processing..." } %>
        <% end %>
      <% elsif session.present? && session.check_out_time.nil? %>
        <% create_at = session.created_at %>
        <div id="timerDisplay" data-created-at="<%= create_at&.iso8601 || nil %>" data-system-time="<%= Time.zone.now.iso8601 %>"></div>
        <script>
          document.addEventListener("turbo:load", function() {
            var timerDisplay = document.getElementById("timerDisplay");
            if (timerDisplay && timerDisplay.getAttribute("data-created-at")) {
              var createdAt = new Date(timerDisplay.getAttribute("data-created-at"));
              var systemTime = new Date(timerDisplay.getAttribute("data-system-time"));

              function updateTimer() {
                var now = new Date();
                var elapsed = now - systemTime + (systemTime - createdAt);
                var hours = Math.floor(elapsed / (1000 * 60 * 60));
                var minutes = Math.floor((elapsed % (1000 * 60 * 60)) / (1000 * 60));
                var seconds = Math.floor((elapsed % (1000 * 60)) / 1000);
                timerDisplay.innerText = `${hours}h ${minutes}m ${seconds}s`;
              }

              setInterval(updateTimer, 1000);
              updateTimer(); // Initial call to display the time immediately
            }
          });
        </script>
      <% end %>
    </div>
  </div>
</div>

  <div style="float: right; margin-top: 20px;">
    <% if session.present? %>
      <% if session.check_out_time.nil? && session.check_in_time.today? %>
      <% if session.breaks.present? %>
        <% if session.breaks.last.break_out_time.nil? %>
          <% content_for :link_button do %>
            <%= button_to "Break-Out", break_session_path, class: "sign-out-button check-btn", id: "checkOutButtonModal", data: { disable_with: "Processing..." } %>
          <% end %>
            <% else %>
          <% content_for :link_button do %>
            <%= button_to "Break-In", break_session_path, class: "sign-out-button check-btn", id: "checkOutButtonModal", data: { disable_with: "Processing..." } %>
        <% end %>
        <% end %>
      <% else %>
          <% content_for :link_button do %>
            <%= button_to "Break-In", break_session_path, class: "sign-out-button check-btn", id: "checkOutButtonModal", data: { disable_with: "Processing..." } %>
        <% end %>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <% if session.present? && session.check_out_time.nil? && current_user.attendances.last.check_in_time >= 16.hours.ago %>
    <% unless session.breaks.present? && session.breaks.last.break_out_time.nil? %>
      <div class="button-container">
        <% content_for :link_button do %>
          <button id="modal-btn" class="sign-out-button">Check Out</button>
        <% end %>
        <div id="myModal" class="modal">
          <div class="modal-checkout">
            <%= form_with url: end_session_path, method: :post, remote: true, id: "checkout_form" do |f| %>
              <div class="modal-header">
                <span class="close-modal icon-position" onclick="document.getElementById('myModal').style.display='none'">&times;</span>
              </div>
              <h4>Daily Report</h4>
              <p style="text-align: center; margin-top: 10px;">
                <%= f.text_area :report, id: "report_editor", placeholder: "Enter Details", style: "width: 100%; height: 150px; resize: vertical; padding: 10px; border-radius: 8px;", required: true %>
              </p>
              <div class="modal-footer">
                <%= f.submit "Submit Report and check out", class: "check-out-btn", onclick: "this.disabled = true; this.value = 'Processing...'; this.form.submit();" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
  </body>
<script>
    document.addEventListener("turbo:load", function() {
      const buttons = document.querySelectorAll('form button.sign-out-button');
      buttons.forEach(button => {
        button.addEventListener('click', function(event) {
          event.preventDefault();
          button.disabled = true;
          button.textContent = button.getAttribute('data-disable-with');
          const form = button.closest('form');
          if (form) {
            form.submit();
          }
        });
      });
    });

  var modal = document.getElementById("myModal");
  var btn = document.getElementById("modal-btn");

  btn.onclick = function() {
    modal.style.display = "block";
  }

  window.onclick = function(event) {
    if (event.target == modal) {
      modal.style.display = "none";
    }
  }


</script>