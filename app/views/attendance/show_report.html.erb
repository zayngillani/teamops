<div class="reportTable">
  <table style="width: 100%;">
    <thead>
      <tr>
        <th>Date</th>
        <th>Report Details</th>
        <th>Action</th>
        <tr><td colspan="3" style="border-bottom: 1px solid black;"></td></tr>
      </tr>
    </thead>
    <tbody>
  <% if @session.present? %>
    <% @session.each do |item| %>
      <tr>
        <td><%= item.created_at.strftime("%d %B, %Y")%></td>
        <td><%= item.report.present? ? truncate(item.report, length: 20) : "N/A" %></td>
        <td>
          <div class="dropdown-action">
            <%= image_tag("more.png", width: "20", height: "20", alt: "Edit User") %>
            <div class="dropdown-content-action">
            <%= button_to "View report", user_report_path(item.id), method: :get, class: "view-report" %>
                    <div id="myModalEdit<%= item.id %>" class="modal">
                      <div class="modal-content">
                        <%= form_with url: update_report_path, method: :put, remote: true, id: "checkout_form" do |f| %>
                          <div class="modal-header"></div>
                          <p style="text-align: center; margin-top: 10px;">
                            <%= f.text_area :report, value: item.report, placeholder: "Enter Daily Report", style: "width: 100%; height: 150px; resize: vertical; padding: 10px; margin-top: 40px;", required: true %>
                            <%= f.hidden_field :id, value: item.id %>
                          </p>
                          <div class="modal-footer">
                            <%= f.submit "Update", class: "report-button", data: { disable_with: "Processing..." } %>
                          </div>
                        <% end %>
                      </div>
                    </div>
            </div>
          </div>
        </td>
        </tr>
      <tr><td colspan="3" style="border-bottom: 1px solid black;"></td></tr>
    <% end %>
  <% else %>
    <tr>
      <td colspan="3">N/A</td>
    </tr>
  <% end %>
    </tbody>
  </table>
</div>

</div>