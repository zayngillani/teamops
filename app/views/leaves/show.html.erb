<div class="main-content" style="margin-left: 220px; margin-top: 10px;">
     <table class="display">
      <thead>
        <tr>
          <th> Start Date</th>
          <th> End Date</th>
          <th> Reason</th>
          <th> Actions</th>
        </tr>
      </thead>
      <tbody>
      <% @leaves.each do |item| %>
        <tr>
          <td><%= item.start_date.strftime("%A, %B %d, %Y") %></td>
          <td><%= item.end_date.strftime("%A, %B %d, %Y") %></td>
          <td><%= item.reason %></td>
          <% if item.status == "approved"%>
          <td>
            <%= button_tag "Approved", type: "button", class: "sign-out-button", disabled: true %>
          </td>
          <% elsif  item.status == "rejected"%>
          <td>
            <%= button_tag "Rejected", type: "button", class: "sign-out-button", disabled: true %>
          </td>
          <% else %>
          <td>
          <%= link_to "Approve", approve_path(id: item.id), class: "sign-out-button"%> 
          <%= link_to "Reject", reject_path(id: item.id), class: "sign-out-button"%>
          </td>
          <% end %>
        </tr>
      <% end %>
      </tbody>
    </table>
 </div>