<div class="main-content" style="margin-left: 220px; margin-top: 10px;">
     <table class="display">
      <thead>
        <tr>
          <th> Start Date</th>
          <th> End Date</th>
          <th> Reason</th>
          <th> Actions</th>
        </tr>
      </thead>
      <tbody>
      <% @leaves.each do |item| %>
        <tr>
          <td><%= item.start_date.strftime("%A, %B %d, %Y") %></td>
          <td><%= item.end_date.strftime("%A, %B %d, %Y") %></td>
          <td><%= item.reason %></td>
          <% if item.status == "approved"%>
          <td>
            <%= button_tag "Approved", type: "button", class: "sign-out-button", disabled: true %>
          </td>
          <% elsif  item.status == "rejected"%>
          <td>
            <%= button_tag "Rejected", type: "button", class: "sign-out-button", disabled: true %>
          </td>
          <% else %>
          <td>
          <div class="leave-container">
           <%= button_to "Approve", approve_path, method: :get, params: { id: item.id }, class: "leave-request approve-btn", id: "approve-btn-#{item.id}", data: { disable_with: "Processing..." } %>
           <%= button_to "Reject", reject_path, method: :get, params: { id: item.id }, class: "leave-request reject-btn", id: "reject-btn-#{item.id}", data: { disable_with: "Processing..." } %>
          </div>
          </td>
          <% end %>
        </tr>
      <% end %>
      </tbody>
    </table>
 </div>

 <script>
 document.addEventListener("DOMContentLoaded", function() {
  // Select all approve and reject buttons
  const approveButtons = document.querySelectorAll('.approve-btn');
  const rejectButtons = document.querySelectorAll('.reject-btn');

  // Disable the button when clicked
  approveButtons.forEach(button => {
    button.addEventListener('click', function() {
      button.disabled = true;
    });
  });

  rejectButtons.forEach(button => {
    button.addEventListener('click', function() {
      button.disabled = true;
    });
  });
});
</script>