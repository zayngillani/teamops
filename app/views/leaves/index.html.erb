<div class="container-leave">
  <div class="container-leaf">
    <strong style="margin-bottom: 10px;">Pending Requests</strong>
    <table class="display">
      <thead>
        <tr>
          <th>User</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
      <% @pending.each do |item| %>
        <tr>
          <td><%= item.user_id %></td>
          <td><%= item.status %></td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>
  
  <div class="container-leaf">
    <strong style="margin-bottom: 10px;">Accepted Requests</strong>
    <table class="display">
      <thead>
        <tr>
          <th>Column 1</th>
          <th>Column 2</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Data 1</td>
          <td>Data 2</td>
        </tr>
      </tbody>
    </table>
  </div>
  
  <div class="container-leaf">
    <strong style="margin-bottom: 10px;">Rejected Requests</strong>
    <table class="display">
      <thead>
        <tr>
          <th>Column 1</th>
          <th>Column 2</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Data 1</td>
          <td>Data 2</td>
        </tr>
      </tbody>
    </table>
  </div>
</div>


