  <div class="container2">
    <%= form_with model: current_user, url: leaves_path, method: :post do |f| %>
      <div class="field">
          <%= f.label :start_date %>
          <%= f.date_field :start_date, min: Date.today, required: true %>
      </div>
      <br>
      <div class="field">
          <%= f.label :end_date %>
          <%= f.date_field :end_date, min: Date.today, required: true %>
     </div>
     <br>
     <div class="field">
          <%= f.label :reason %>
          <%= f.text_area :reason, class: "text-area", required: true %>
     </div>
     <br>
      <div class="actions">
        <%= f.submit "Request", class: "orange-button" %>
      </div>
    <% end %>
  </div>