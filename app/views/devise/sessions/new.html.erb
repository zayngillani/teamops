<!DOCTYPE html>
<html>
<head>
  <title>Login Page</title>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
  <style>
    body, html {
      height: 100%;
      margin: 0;
      font-family: Arial, sans-serif;
    }

    .login-container {
      display: flex;
      height: 100vh;
      width: 100%;
      margin: 0 auto;
      max-width: 240px;
      padding: 70px 5px;
    }

    .background-image {
      flex: 1;
      background-size: cover;
    }

    .login-form {
      margin-top: auto;
      width: 120%;
      margin-left: -10%;
    }

    .form-group {
      margin-bottom: 20px;
    }

    .form-control {
      width: 100%;
      padding: 10px;
      margin-top: 5px;
    }

    .btn-primary {
      width: 100%;
      padding: 10px;
      background-color: #007bff;
      border: none;
      color: white;
      cursor: pointer;
    }

    .btn-primary:hover {
      background-color: #0056b3;
    }

    .f-link {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 11%;
    }

    .log-in-button {
      background-color: #F89320;
      border: none;
      color: white;
      padding: 10px 20px;
      text-align: center;
      text-decoration: none;
      display: inline-block;
      font-size: 16px;
      margin-right: 10px;
      border-radius: 5px;
      cursor: pointer;
      width: 280px;
    }

      .logos img {
     width: 100px;
     height: auto;
     margin-left: 25%;
     margin-bottom: 8%;
    }

  </style>
</head>
<body>
<div class="background-image" style="background-image: url('<%= asset_path('tecerlogin.svg') %>');">
    <div class="login-container">
      <div class="login-form">
       <a href="/" class="logos">
    <%= image_tag "tecerlogo.svg" %>
  </a>
        <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
         <% if notice %>
            <div class="alert alert-success fading-out" id="banner"><%= notice %></div>
          <% end %>
          <% if alert %>
            <div class="alert alert-danger fading-out" id="banner"><%= alert %></div>
          <% end %>
          <div class="form-group">
            <%= f.label :email %>
            <%= f.email_field :email, autofocus: true, class: 'form-control', autocomplete: "email", placeholder: "Email", required: true %>
          </div>
          <div class="form-group">
            <%= f.label :password %>
            <%= f.password_field :password, autocomplete: "current-password", class: 'form-control', placeholder: "Password", required: true %>
          </div>
          <div class="f-link">
            <%= link_to "Forgot Password?", new_user_password_path(resource_name), style: "color: black;" %>
          </div>  
          <div class="form-group">
            <%= f.submit "Login", class: "log-in-button" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</body>
</html>
