<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
     <title>Login</title> 
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.2/css/all.min.css"/>
  </head>
  <body class="special-background">
    <div class="container">
      <div class="wrapper">
        <div class="title"><span>Forgot Password?</span></div>
        <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
          <% if resource.errors.full_messages.present? %>
            <div class="alert alert-danger fading-out" id="banner"><%= resource.errors.full_messages[0] %></div>
          <% end %>
          <div class="row">
            <i class="fas fa-user"></i>
              <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "Email", required: true %>
          </div>
              <%= f.submit "Reset Password", class: "sign-in-button" %>
          <% end %>
      </div>
    </div>

  </body>
</html>